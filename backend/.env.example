# ============================================
# SEEKHOWITHRUA ENVIRONMENT VARIABLES
# NEVER COMMIT THIS FILE WITH REAL VALUES
# Copy this to .env and fill in real values
# ============================================

# ============================================
# DJANGO CORE SETTINGS
# ============================================
SECRET_KEY=your-django-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=seekhowithrua.com,app.seekhowithrua.com,api.seekhowithrua.com

# ============================================
# DATABASE - Supabase PostgreSQL
# ============================================
DB_NAME=postgres
DB_USER=your-supabase-user
DB_PASSWORD=your-supabase-password
DB_HOST=your-supabase-host.pooler.supabase.com
DB_PORT=6543

# Alternative: Use DATABASE_URL for Render
DATABASE_URL=postgresql://user:password@host:port/dbname

# ============================================
# EMAIL SETTINGS - Gmail SMTP
# ============================================
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SeekhoWithRua <noreply@seekhowithrua.com>
SERVER_EMAIL=noreply@seekhowithrua.com

# ============================================
# PAYMENT SETTINGS
# ============================================
# UPI ID for Indian payments
LMS_UPI_ID=your-upi-id@upi

# Stripe (for international payments)
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay (for Indian payments)
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================
# GROQ AI API (for TalkWithRua)
# ============================================
GROQ_API_KEY=gsk_your_groq_api_key

# Frontend Vite env
VITE_GROQ_API_KEY=gsk_your_groq_api_key

# ============================================
# GOOGLE OAUTH (for Google Sign-In)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# REDIS & CELERY
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# CLOUD STORAGE (for media files)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=seekhowithrua-media
AWS_S3_REGION_NAME=ap-south-1

# ============================================
# SECURITY HEADERS
# ============================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ============================================
# LMS PRICING CONFIG
# ============================================
LMS_MONTHLY_FEE=1000
LMS_REFERRAL_CONCESSION=200

# ============================================
# BUNDLE PACK PRICING (in paise for Razorpay, cents for Stripe)
# ============================================
BUNDLE_PACK_PRICE_INR=29900
BUNDLE_PACK_PRICE_USD=9900
